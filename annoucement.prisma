// Represents a single announcement created by an admin and visible to all users.
model Announcement {
  id          String      @id @default(uuid())      // Unique identifier for each announcement
  title       String                                 // Title of the announcement
  message     String       @db.Text                 // Main body content of the announcement
  createdAt   DateTime     @default(now())          // Timestamp of when the announcement was created
  updatedAt   DateTime     @updatedAt               // Timestamp of the last update (edit)
  authorId    String?                               // ID of the admin who created the announcement

  // Optional status fields for extended functionality
  isActive    Boolean      @default(true)           // Whether the announcement is still visible to users
  expiresAt   DateTime?                             // Optional expiration date to hide the announcement automatically

  // RELATIONS
  author      User?         @relation(fields: [authorId], references: [id])  // Link to the admin who posted it
  notifications AnnouncementNotification[]                                   // List of notifications sent to users

  // Index for retrieving announcements by creation date quickly (most recent first)
  @@index([createdAt])
}

// Tracks which users have received or read each announcement (for notifications and analytics).
model AnnouncementNotification {
  id              String         @id @default(uuid())      // Unique identifier for each record
  announcementId  String                                 // Reference to the announcement
  userId          String                                 // Reference to the user
  isRead          Boolean        @default(false)          // Whether the user has viewed/read the announcement
  sentAt          DateTime       @default(now())          // Timestamp of when the email/notification was sent

  // RELATIONS
  announcement    Announcement   @relation(fields: [announcementId], references: [id])
  user            User           @relation(fields: [userId], references: [id])

  // Ensures one record per announcement-user pair
  @@unique([announcementId, userId])
}
