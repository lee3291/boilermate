model BugReport {
  id          String   @id @default(uuid())
  title       String
  description String
  steps       String
  userId      String // Purdue ID 
  status      String  @default("OPEN") // OPEN | IN_PROGRESS | RESOLVED | CLOSED
  priority    String? // HIGH | MEDIUM | LOW
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
