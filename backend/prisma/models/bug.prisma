generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client-bug"
}

datasource db {
  provider = "postgresql"
  url      = env("Bo_URL")
}

model BugReport {
  id            String    @id @default(dbgenerated("LPAD((FLOOR(RANDOM() * 90000000 + 10000000))::text, 8, '0')")) @db.VarChar(8)
  title         String
  description   String
  stepsToReprod String
  status        String    @default("open")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
