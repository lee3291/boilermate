// An enum to manage the status of an invitation.
enum ChatParticipantStatus {
  PENDING   // The user has been invited but has not responded.
  ACCEPTED  // The user has accepted the invitation and is a member.
  DECLINED  // The user has declined the invitation.
}

// Represents a single conversation, which can be a 1-on-1 DM or a group chat.
model Chat {
  id        String   @id @default(uuid()) // id of the chatbox itself
  isGroup   Boolean  @default(false)     // True if this is a group chat, false for DMs.
  name      String?                     // Optional name for group chats.
  groupIcon String?                     // Optional URL for a group chat's icon.
  creatorId String?                     // The user ID of the person who created the group. Null for DMs.
  latestMessageAt DateTime // time of the latest message, this is used to sort user conversation

  // RELATIONS
  messages     Message[]        // A chat has many messages.
  participants ChatParticipant[]  // A chat has many participants (members).
  creator      User?            @relation(fields: [creatorId], references: [id])
  
  // Index for fast sorting of the user's conversation list
  @@index([latestMessageAt])
}

// This is the "join table" that connects Users to Chats.
// It holds information about a user's membership in a specific chat.
model ChatParticipant {
  id        String                @id @default(uuid())
  chatId    String
  userId    String
  status    ChatParticipantStatus @default(PENDING) // Status of the user's invitation/membership.
  
  // RELATIONS
  chat      Chat                  @relation(fields: [chatId], references: [id])
  user      User                  @relation(fields: [userId], references: [id])

  // Ensures a user can only be a participant in a given chat once.
  @@unique([userId, chatId])
}


model Message {
  id               String      @id @default(uuid())
  chatId           String
  senderId         String
  content          String?     @db.Text
  imageId          String?
  isEdited         Boolean     @default(false)
  isDeleted        Boolean     @default(false) // delete message for everyone
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt // Timestamp of the last edit
  // Relations
  chat             Chat        @relation(fields: [chatId], references: [id])
  sender           User        @relation(fields: [senderId], references: [id])
  statuses         UserMessageStatus[] // Link to per-user statuses
  image            Image?      @relation(fields: [imageId], references: [id]) // link image id to image object
  approvals        MessageApproval[] // Link to all approve image message

  // Index for fast retrieval and sorting within a single chat thread
  @@index([chatId, createdAt])
}

model UserMessageStatus {
  id               String      @id @default(uuid())
  userId           String
  messageId        String

  isDeleted        Boolean     @default(true)
  // have this for an easier to integrate workflow => technically doesn't need it but good for more flexibility

  user             User        @relation(fields: [userId], references: [id])
  message          Message     @relation(fields: [messageId], references: [id])

  @@unique([userId, messageId])
}

model MessageApproval {
  id         String   @id @default(uuid())
  messageId  String
  userId     String   // The reciever who approve/unapprove the image
  approved   Boolean
  message    Message  @relation(fields: [messageId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([messageId, userId]) // One approval per user per message
}

model UserBlocking {
  id        String   @id @default(uuid())
  blockerId String   // the person doing the block
  blockedId String   // the person being blocked
  createdAt DateTime @default(now())

  blocker   User     @relation("UserBlocked", fields: [blockerId], references: [id])
  blocked   User     @relation("UserBlockedBy", fields: [blockedId], references: [id])

  @@unique([blockerId, blockedId])
}

