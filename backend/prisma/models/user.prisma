model User {
  id            String        @id @default(uuid())
  email         String        @unique
  passwordHash  String
  profileInfo   Json?
  avatarURL     String?
  phoneNumber   String?
  bio           String?
  isVerified    Boolean       @default(false)
  status        UserStatus?   @default(ACTIVE)
  searchStatus  SearchStatus? @default(LOOKING)
  preferences   Preference[]
  listings      Listing[]

  // RELATIONS for the new chat system
  // Connects the user to all the chats they are a member or invitee of.
  participatedChats ChatParticipant[]

  // Connects the user to all the group chats they have created.
  createdChats     Chat[]

  // 3. Message Sender - Opposite of Message.sender
  messagesSent     Message[]
  messageStatuses  UserMessageStatus[]

  // 4. Image owner - Opposite of Image.user
  images           Image[]
  approvals        MessageApproval[]

  // Block/Unblock in chat
  usersBlocked   UserBlocking[] @relation("UserBlocked")      // users that this user has blocked
  blockedByUsers UserBlocking[] @relation("UserBlockedBy")   // users who blocked this user
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum SearchStatus {
  LOOKING
  NOT_LOOKING
  HIDDEN
}


