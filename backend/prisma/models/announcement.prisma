model Announcement {
  id          String      @id @default(uuid())
  title       String
  message     String       @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  authorId    String?

  // Relation back to User (named relation for clarity)
  author      User?        @relation("UserAnnouncements", fields: [authorId], references: [id], onDelete: Cascade)

  // Optional status fields
  isActive    Boolean      @default(true)
  expiresAt   DateTime?

  notifications AnnouncementNotification[]
  @@index([createdAt])
}

model AnnouncementNotification {
  id              String         @id @default(uuid())
  announcementId  String
  userId          String
  isRead          Boolean        @default(false)
  sentAt          DateTime       @default(now())

  // Relations
  announcement    Announcement   @relation(fields: [announcementId], references: [id])
  user            User           @relation("UserAnnouncementNotifications", fields: [userId], references: [id])

  @@unique([announcementId, userId])
}
