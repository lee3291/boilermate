model Announcement {
  id          String      @id @default(uuid())
  title       String
  message     String       @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  authorId    String?

  // Relation back to User (named relation for clarity)
  author      User?        @relation("UserAnnouncements", fields: [authorId], references: [id], onDelete: Cascade)

  // Optional status fields
  isActive    Boolean      @default(true)
  expiresAt   DateTime?
  scheduledAt DateTime?

  notifications AnnouncementNotification[]

  // Like system
  likes         Int                  @default(0)
  likedBy       String[]             @default([]) // optional cache/legacy
  likesList     AnnouncementLike[]   @relation("AnnouncementLikes")

  @@index([createdAt])
}

model AnnouncementNotification {
  id              String         @id @default(uuid())
  announcementId  String
  userId          String
  isRead          Boolean        @default(false)
  sentAt          DateTime       @default(now())

  // Relations
  announcement    Announcement   @relation(fields: [announcementId], references: [id])
  user            User           @relation("UserAnnouncementNotifications", fields: [userId], references: [id])

  @@unique([announcementId, userId])
}

model AnnouncementLike {
  id              String        @id @default(uuid())
  userId          String
  announcementId  String
  createdAt       DateTime      @default(now())

  user            User          @relation("UserLikes", fields: [userId], references: [id])
  announcement    Announcement  @relation("AnnouncementLikes", fields: [announcementId], references: [id])

  @@unique([userId, announcementId])
  @@index([announcementId])
}
