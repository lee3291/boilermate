enum ListingStatus {
  ACTIVE
  ARCHIVED
  RESOLVED
}

// ---------------- Core: Listing ----------------
// (from diagram: listingID, creatorID, title, description, pricing, location, media, status, viewCount, createdAt)
model Listing {
  id          String        @id @default(cuid())
  creatorId   String

  title       String
  description String        @db.Text
  price       Int
  location    String

  mediaUrls   String[]
  status      ListingStatus @default(ACTIVE)

  viewCount   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([location])
  @@index([price])
}

