enum ListingStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

// ---------------- Core: Listing ----------------
// (from diagram: listingID, creatorID, title, description, pricing, location, media, status, viewCount, createdAt)
// creatorId   String?
model Listing {
  id          String        @id @default(cuid())

  title       String
  user        String        @default("Anonymous")
  description String        @db.Text
  price       Int
  pricing     Float         @default(0)
  location    String

  mediaUrls   String[]
  status      ListingStatus @default(ACTIVE)

  moveInStart DateTime?     @db.Date
  moveInEnd   DateTime?     @db.Date
  viewCount   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  saves       Saved[]

  userId      String?
  userrel     User?        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([location])
  @@index([price])
}

model Saved {
  username   String
  listingId  String

  listing    Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)

  createdAt  DateTime      @default(now())

  @@id([username, listingId])

  @@index([username])
  @@index([listingId])
}
