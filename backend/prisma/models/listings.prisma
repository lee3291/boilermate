enum ListingStatus {
  ACTIVE
  ARCHIVED
  RESOLVED
}

// ---------------- Core: Listing ----------------
// (from diagram: listingID, creatorID, title, description, pricing, location, media, status, viewCount, createdAt)
// creatorId   String?
model Listing {
  id          String        @id @default(cuid())

  title       String
  user        String        @default("Anonymous")
  description String        @db.Text
  price       Int
  location    String

  mediaUrls   String[]
  status      ListingStatus @default(ACTIVE)

  moveInStart DateTime?     @db.Date
  moveInEnd   DateTime?     @db.Date
  viewCount   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([location])
  @@index([price])
}

