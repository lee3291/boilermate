model Listing {
  listingID        String      @id @default(uuid())
  userID           String
  title            String
  description      String
  pricing          Float
  location         String
  media            String[]
  status           Status
  viewCount        Int         @default(0)
  createdAt        DateTime    @default(now())
  user             User        @relation(fields: [userID], references: [id], onDelete: Cascade)
}

enum Status {
  ACTIVE
  INACTIVE
  ARCHIVED
}
