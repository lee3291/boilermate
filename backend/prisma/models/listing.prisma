model Listing {
  listingID        String      @id @default(uuid())
  userID           String
  title            String
  description      String
  pricing          Int
  media            String[]
  status           Status
  numberBed        Int
  numberBath       Int
  viewCount        Int         @default(0)
  createdAt        DateTime    @default(now())
  user             User        @relation(fields: [userID], references: [id], onDelete: Cascade)
}

enum Status {
  ACTIVE
  INACTIVE
  ARCHIVED
}
