model Image {
  id        String   @id @default(uuid()) // Unique identifier for the image
  key       String   @unique // S3 object key (unique filename in bucket)
  url       String   // The full S3 URL of the image
  userId    String   // The ID of the user who uploaded it
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id]) // The user who uploaded this image
  messages  Message[] // Messages that use this image
}
