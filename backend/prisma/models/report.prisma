generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client-report"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Report {
  id              Int       @id @default(autoincrement())
  reporterId      Int
  reportedUserId  Int
  reason          String
  comments        String
  status          String    @default("unresolved")
  createdAt       DateTime  @default(now())
}
