<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Account Verified</title>
    <style>
      body {
        font-family: sans-serif;
        background-color: #f4f4f4;
        color: #333;
        line-height: 1.6;
      }
      .container {
        max-width: 600px;
        margin: 20px auto;
        padding: 20px;
        background: #fff;
        border: 1px solid #ddd;
      }
      .header {
        background: #004aad;
        color: #ffffff;
        padding: 10px;
        text-align: center;
      }
      .content {
        padding: 20px;
      }
      .footer {
        margin-top: 20px;
        text-align: center;
        font-size: 0.8em;
        color: #666;
      }
    </style>
  </head>
  <body>
    <div class='container'>
      <div class='header'>
        <h1>BoilerMate</h1>
      </div>
      <div class='content'>
        <h2>Congratulations, {{userName}}! Your Account is Verified!</h2>
        <p>
          Your BoilerMate account has been successfully verified. You now have a
          verified badge next to your name, which will help build trust within
          the community.
        </p>
        <p>
          Thank you for helping us keep BoilerMate a safe and trusted platform.
        </p>
        <p>
          Best regards,<br />
          The BoilerMate Team
        </p>
      </div>
      <div class='footer'>
        <p>&copy; 2025 BoilerMate. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>