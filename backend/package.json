{
  "name": "boilermate-be",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prisma:generate": "prisma generate --schema ./prisma",
    "prisma:migrate": "prisma migrate dev --schema ./prisma",
    "prisma:seed": "ts-node prisma/seeds/preferences.seed.ts",
    "prisma:reset": "prisma migrate reset",
    "start -d": "dotenv -e .env -e .env.dev -- nest start",
    "start:dev -d": "dotenv -e .env -e .env.dev -- nest start --watch",
    "start:debug -d": "dotenv -e .env -e .env.dev -- nest start --debug --watch",
    "prisma:generate -d": "dotenv -e .env -e .env.dev -- prisma generate --schema ./prisma",
    "prisma:migrate -d": "dotenv -e .env -e .env.dev -- prisma migrate dev --schema ./prisma",
    "prisma:seed -d": "dotenv -e .env -e .env.dev -- ts-node prisma/seeds/preferences.seed.ts",
    "prisma:reset -d": "dotenv -e .env -e .env.dev -- prisma migrate reset",
    "test": "dotenv -e .env -e .env.test -- jest",
    "test:watch": "dotenv -e .env -e .env.test -- jest --watch",
    "test:cov": "dotenv -e .env -e .env.test -- jest --coverage",
    "test:debug": "dotenv -e .env -e .env.test -- node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "dotenv -e .env -e .env.test -- jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.908.0",
    "@aws-sdk/client-s3": "^3.908.0",
    "@aws-sdk/s3-request-presigner": "^3.910.0",
    "@nestjs/common": "^11.1.8",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/platform-socket.io": "^11.1.6",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/websockets": "^11.1.6",
    "@prisma/client": "^6.19.0",
    "@sendgrid/mail": "^8.1.6",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "express": "^5.1.0",
    "nodemailer": "^7.0.6",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/date-fns": "^2.5.3",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/node-fetch": "^2.6.13",
    "@types/nodemailer": "^7.0.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^6.19.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
